# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=your-super-secret-jwt-key-here

# App
PORT=3001
CLIENT_URL=http://localhost:5173

# Stripe (use test keys from dashboard.stripe.com)
# sk_test_... from Developers > API keys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Create a product + price in Stripe dashboard, copy the price ID (price_...)
STRIPE_PRO_PRICE_ID=price_YOUR_PRICE_ID_HERE

# Run: stripe listen --forward-to localhost:3001/api/billing/webhook
# Copy the "whsec_..." key printed in terminal
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Resend (resend.com) — email delivery
# In test mode, use "Resend Test" API key and send FROM onboarding@resend.dev
RESEND_API_KEY=re_YOUR_KEY_HERE
EMAIL_FROM=Schedully <noreply@schedully.app>
